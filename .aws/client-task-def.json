{
    "family": "shopsmart-client-task",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "client",
            "image": "131811362452.dkr.ecr.us-east-1.amazonaws.com/shopsmart-client:latest",
            "portMappings": [
                {
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/shopsmart-client",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs",
                    "awslogs-create-group": "true"
                }
            }
        }
    ],
    "requiresCompatibilities": [ "FARGATE" ],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::131811362452:role/LabRole"
}
